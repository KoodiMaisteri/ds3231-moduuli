<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="$M0s6hGt~@a?]0*?T+Q%" x="20" y="20"><statement name="HANDLER"><block type="typescript_statement" id="x9q8iB~u-iI)klxUwks["><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace RTC {" line1="    const RTC_ADDR = 104; // 0x68 desimaalina" line2="    const REG_SEC = 0;" line3="" line4="    // --- APUFUNKTIOT (BCD-muunnokset) ---" line5="    function decToBcd(val: number): number {" line6="        return Math.floor(val / 10) * 16 + (val % 10);" line7="    }" line8="" line9="    function bcdToDec(val: number): number {" line10="        return Math.floor(val / 16) * 10 + (val % 16);" line11="    }" line12="" line13="    function lueRekisteri(reg: number): number {" line14="        pins.i2cWriteNumber(RTC_ADDR, reg, NumberFormat.UInt8BE, false);" line15="        return pins.i2cReadNumber(RTC_ADDR, NumberFormat.UInt8BE, false);" line16="    }" line17="" line18="    /**" line19="     * Asettaa RTC-kellon ajan ja päivämäärän. Sekunnit nollautuvat automaattisesti." line20="     * @param vuosi esim. 2026" line21="     * @param kuukausi 1-12" line22="     * @param paiva 1-31" line23="     * @param tunti 0-23" line24="     * @param minuutti 0-59" line25="     */" line26="    //% block=&quot;Aseta aika: vuosi %vuosi kuukausi %kuukausi päivä %paiva tunti %tunti minuutti %minuutti&quot;" line27="    //% weight=100" line28="    //% vuosi.min=2000 vuosi.max=2099 vuosi.defl=2026" line29="    //% kuukausi.min=1 kuukausi.max=12 kuukausi.defl=1" line30="    //% paiva.min=1 paiva.max=31 paiva.defl=1" line31="    //% tunti.min=0 tunti.max=23 tunti.defl=12" line32="    //% minuutti.min=0 minuutti.max=59 minuutti.defl=0" line33="    export function asetaAika(vuosi: number, kuukausi: number, paiva: number, tunti: number, minuutti: number): void {" line34="        let buf = pins.createBuffer(8);" line35="        let lyhytVuosi = vuosi % 100; // DS3231 tallentaa vain kaksi viimeistä numeroa" line36="        let sekunti = 0;" line37="        let viikonpaiva = 1; // Oletusarvo, jos viikonpäivää ei tarvita" line38="" line39="        buf[0] = REG_SEC;" line40="        buf[1] = decToBcd(sekunti);" line41="        buf[2] = decToBcd(minuutti);" line42="        buf[3] = decToBcd(tunti);" line43="        buf[4] = decToBcd(viikonpaiva);" line44="        buf[5] = decToBcd(paiva);" line45="        buf[6] = decToBcd(kuukausi);" line46="        buf[7] = decToBcd(lyhytVuosi);" line47="" line48="        pins.i2cWriteBuffer(RTC_ADDR, buf);" line49="    }" line50="" line51="    /**" line52="     * Palauttaa ajan muodossa HH:MM:SS" line53="     */" line54="    //% block=&quot;Lue aika (hh:mm:ss)&quot;" line55="    //% weight=90" line56="    export function lueAika(): string {" line57="        pins.i2cWriteNumber(RTC_ADDR, REG_SEC, NumberFormat.UInt8BE, false);" line58="        // Luetaan 3 tavua kerralla: sekunnit, minuutit, tunnit" line59="        let timeBuf = pins.i2cReadBuffer(RTC_ADDR, 3);" line60="" line61="        let sekunti2 = bcdToDec(timeBuf[0] &amp; 0x7F);" line62="        let minuutti = bcdToDec(timeBuf[1]);" line63="        // Maskataan bitit 0x3F, jotta 12/24h moodibitit eivät sotke lukua" line64="        let tunti = bcdToDec(timeBuf[2] &amp; 0x3F);" line65="" line66="        // Lisätään nolla eteen, jos luku on alle 10" line67="        let strTunti = (tunti &lt; 10 ? &quot;0&quot; : &quot;&quot;) + tunti;" line68="        let strMin = (minuutti &lt; 10 ? &quot;0&quot; : &quot;&quot;) + minuutti;" line69="        let strSek = (sekunti2 &lt; 10 ? &quot;0&quot; : &quot;&quot;) + sekunti2;" line70="" line71="        return strTunti + &quot;:&quot; + strMin + &quot;:&quot; + strSek;" line72="    }" line73="" line74="    /**" line75="     * Palauttaa tallennetun vuoden (esim. 2026)" line76="     */" line77="    //% block=&quot;Vuosi&quot;" line78="    //% weight=80" line79="    export function lueVuosi(): number {" line80="        let val = lueRekisteri(6); // Rekisteri 0x06" line81="        return 2000 + bcdToDec(val);" line82="    }" line83="" line84="    /**" line85="     * Palauttaa tallennetun kuukauden (1-12)" line86="     */" line87="    //% block=&quot;Kuukausi&quot;" line88="    //% weight=75" line89="    export function lueKuukausi(): number {" line90="        let val2 = lueRekisteri(5); // Rekisteri 0x05" line91="        return bcdToDec(val2 &amp; 0x1F); // Maskataan pois mahdollinen vuosisatabitti" line92="    }" line93="" line94="    /**" line95="     * Palauttaa tallennetun päivän (1-31)" line96="     */" line97="    //% block=&quot;Päivä&quot;" line98="    //% weight=70" line99="    export function luePaiva(): number {" line100="        let val3 = lueRekisteri(4); // Rekisteri 0x04" line101="        return bcdToDec(val3 &amp; 0x3F);" line102="    }" line103="" line104="    /**" line105="     * Palauttaa tallennetun tunnin (0-23)" line106="     */" line107="    //% block=&quot;Tunti&quot;" line108="    //% weight=65" line109="    export function lueTunti(): number {" line110="        let val4 = lueRekisteri(2); // Rekisteri 0x02" line111="        return bcdToDec(val4 &amp; 0x3F);" line112="    }" line113="" line114="    /**" line115="     * Palauttaa tallennetut minuutit (0-59)" line116="     */" line117="    //% block=&quot;Minuutti&quot;" line118="    //% weight=60" line119="    export function lueMinuutti(): number {" line120="        let val5 = lueRekisteri(1); // Rekisteri 0x01" line121="        return bcdToDec(val5 &amp; 0x7F);" line122="    }" line123="" line124="    /**" line125="     * Palauttaa tallennetut sekunnit (0-59)" line126="     */" line127="    //% block=&quot;Sekunnit&quot;" line128="    //% weight=55" line129="    export function lueSekunnit(): number {" line130="        let val6 = lueRekisteri(0); // Rekisteri 0x00" line131="        return bcdToDec(val6 &amp; 0x7F);" line132="    }" line133="}" numlines="134"></mutation></block></statement></block></xml>